# easier navigation
alias docs="cd ~/Documents"
alias downloads="cd ~/Downloads"
alias desktop="cd ~/Desktop"
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias ~="cd ~"

# programs
alias slt="sublime"

# be nice
alias pls="sudo"

# apt
alias apt-install="apt-get install"
alias apt-update="apt-get update"
alias apt-remove="apt-get remove"

#shortcuts
alias v="vim"
alias g="git"
