execute pathogen#infect()
syntax on
filetype plugin indent on

set wrap
set linebreak
set textwidth=0
set wrapmargin=0

" For setting default colorscheme
colorscheme jellybeans

" For setting tab width
set tabstop=4
set shiftwidth=4
set expandtab

" For setting line number
set number

" Emmet settings
let g:user_emmet_expandabbr_key='<Tab>'
let g:use_emmet_complete_tag=1
