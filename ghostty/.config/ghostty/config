# Colors
theme = catppuccin-macchiato
background = #07070a
background-opacity = 0.88
background-blur-radius = 30

# Fonts
font-size = 16
font-feature = -liga

# Cursor
cursor-style = block
cursor-style-blink = false

# Mouse
mouse-hide-while-typing = true

# macOS
macos-titlebar-style = tabs

# Keybindings
keybind = cmd+shift+t=toggle_quick_terminal
